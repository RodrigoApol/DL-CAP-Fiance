{
  "name": "DL-CAP-Fiance",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@cap-js/postgres": "^3",
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^3",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-app-categories": "cds watch --open com.capfiance.category.appcategories/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-app-wallats": "cds watch --open com.capfiance.wallat.appwallats/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-app-movements-types": "cds watch --open com.capfiance.movements.types.appmovementstypes/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-app-movements": "cds watch --open com.capfiance.movement.appmovements/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-app-wallets": "cds watch --open com.capfiance.wallet.appwallets/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/app-categories",
    "app/app-wallats",
    "app/app-movements-types",
    "app/app-movements",
    "app/app-wallets",
    "app/app-movements",
    "app/app-movements"
  ]
}
