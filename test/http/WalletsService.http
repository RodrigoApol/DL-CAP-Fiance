@server=http://localhost:4004
@username=alice
@password=


### Wallets
# @name Wallets_GET
GET {{server}}/wallets/Wallets
Authorization: Basic {{username}}:{{password}}


### Wallets Drafts GET
# @name Wallets_Drafts_GET
GET {{server}}/wallets/Wallets?$filter=(IsActiveEntity eq false)
Authorization: Basic {{username}}:{{password}}


### Wallets Draft POST
# @name Wallets_Draft_POST
POST {{server}}/wallets/Wallets
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{
  "name": "name-17803957",
  "createdAt": "2014-03-16T02:00:00.000Z",
  "createdBy": "createdBy.allmd@example.com",
  "modifiedAt": "2020-01-25T02:00:00.000Z",
  "modifiedBy": "modifiedBy.allmd@example.com"
}


### Result from POST request above
@draftID={{Wallets_Draft_POST.response.body.$.ID}}


### Wallets Draft PATCH
# @name Wallets_Draft_Patch
PATCH {{server}}/wallets/Wallets(ID={{draftID}},IsActiveEntity=false)
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{
  "name": "name-17803957",
  "createdAt": "2014-03-16T02:00:00.000Z",
  "createdBy": "createdBy.allmd@example.com",
  "modifiedAt": "2020-01-25T02:00:00.000Z",
  "modifiedBy": "modifiedBy.allmd@example.com"
}


### Wallets Draft Prepare
# @name Wallets_Draft_Prepare
POST {{server}}/wallets/Wallets(ID={{draftID}},IsActiveEntity=false)/WalletsService.draftPrepare
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{}


### Wallets Draft Activate
# @name Wallets_Draft_Activate
POST {{server}}/wallets/Wallets(ID={{draftID}},IsActiveEntity=false)/WalletsService.draftActivate
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{}
